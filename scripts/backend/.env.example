# Personal Agent — Ortam Değişkenleri
# Kullanım: cp .env.example .env  →  değerleri doldur  →  ./install.sh

# ── WhatsApp Cloud API ────────────────────────────────────────────
# Meta Developer portalından WhatsApp > API Setup ekranındaki kalıcı erişim token'ı.
# Permanent access token from Meta Developer > WhatsApp > API Setup.
WHATSAPP_TOKEN=YOUR_WHATSAPP_ACCESS_TOKEN

# Meta Developer portalından WhatsApp > API Setup ekranındaki telefon numarası kimliği.
# Phone Number ID from Meta Developer > WhatsApp > API Setup.
WHATSAPP_PHONE_ID=YOUR_PHONE_NUMBER_ID

# Webhook gelen mesajlarının gerçekten Meta'dan geldiğini doğrulamak için kullanılan HMAC imzalama anahtarı.
# HMAC signing secret used to verify that incoming webhook payloads are genuinely from Meta.
WHATSAPP_APP_SECRET=YOUR_APP_SECRET

# Webhook URL'sini Meta'ya kayıt ederken kullanılan doğrulama token'ı; kendin belirle.
# Verification token you set when registering the webhook URL in Meta Developer portal.
WHATSAPP_VERIFY_TOKEN=YOUR_WEBHOOK_VERIFY_TOKEN

# Ajan komutlarını gönderecek tek yetkili WhatsApp numarası (başında + ve ülke kodu).
# The sole authorized WhatsApp number that can send commands to the agent (include + and country code).
WHATSAPP_OWNER=90XXXXXXXXXX

# Meta Graph API sürümü; WhatsApp Cloud API'nin hangi versiyonunu kullanacağını belirler.
# Meta Graph API version; determines which version of the WhatsApp Cloud API will be used.
WHATSAPP_API_VERSION=v19.0

# ── Güvenlik ─────────────────────────────────────────────────────
# /agent/* REST endpoint'lerini korumak için kullanılan API anahtarı (X-Api-Key header'ı).
# API key protecting /agent/* REST endpoints, sent as the X-Api-Key header.
API_KEY=YOUR_INTERNAL_API_KEY

# Sahibin tüm korumalı komutlarda kimliğini doğrulaması için kullanılan TOTP sırrı (Base32 formatı).
# Oluşturmak için: python -c "import pyotp; print(pyotp.random_base32())"
# Base32 TOTP secret used by the owner to authenticate all protected commands.
# Generate with: python -c "import pyotp; print(pyotp.random_base32())"
TOTP_SECRET=YOUR_BASE32_TOTP_SECRET

# ── Anthropic / Claude ────────────────────────────────────────────
# Anthropic API anahtarı; claude.ai/settings > API Keys sayfasından edinilir.
# Anthropic API key; obtain it from claude.ai/settings > API Keys.
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY

# Sohbet ve genel görevler için kullanılacak varsayılan Claude modeli.
# Default Claude model used for conversations and general tasks.
DEFAULT_MODEL=claude-sonnet-4-6

# Niyet sınıflandırması için kullanılan model; hız ve maliyet dengesi için küçük model önerilir.
# Model used for intent classification; a smaller/faster model is recommended to reduce cost.
INTENT_CLASSIFIER_MODEL=claude-haiku-4-5-20251001

# ── LLM Adaptör Seçimi ────────────────────────────────────────────
# Hangi LLM altyapısının kullanılacağını belirler: anthropic (varsayılan) | ollama | gemini
# Selects the active LLM backend: anthropic (default) | ollama | gemini
LLM_BACKEND=anthropic

# Yerel Ollama sunucusunun adresi; LLM_BACKEND=ollama seçildiğinde zorunludur.
# URL of the local Ollama server; required when LLM_BACKEND=ollama.
# OLLAMA_BASE_URL=http://localhost:11434

# Ollama'da kullanılacak model adı.
# Model name to use with Ollama.
# OLLAMA_MODEL=llama3

# Google AI Studio'dan edinilen Gemini API anahtarı; LLM_BACKEND=gemini seçildiğinde zorunludur.
# Gemini API key from aistudio.google.com; required when LLM_BACKEND=gemini.
# GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Kullanılacak Gemini modeli.
# Gemini model name to use.
# GEMINI_MODEL=gemini-2.0-flash

# ── Servis Portları ───────────────────────────────────────────────
# FastAPI (Uvicorn) sunucusunun dinleyeceği port.
# Port on which the FastAPI (Uvicorn) server will listen.
PORT=8010

# Claude Code Bridge (Node.js) sunucusunun dinleyeceği port.
# Port on which the Claude Code Bridge (Node.js) server will listen.
BRIDGE_PORT=8013

# ── Claude Code Bridge Ayarları ──────────────────────────────────
# FastAPI'nin Bridge'e istek göndereceği adres; genellikle değiştirilmez.
# Address FastAPI uses to send requests to the Bridge; usually does not need to change.
CLAUDE_BRIDGE_URL=http://localhost:8013

# Claude Code CLI izin modu: bypassPermissions = otomatik onay, default = her araç için onay ister.
# Claude Code CLI permission mode: bypassPermissions = auto-approve, default = prompt for each tool.
CLAUDE_CODE_PERMISSIONS=bypassPermissions

# Tek bir sorguda Claude Code'un yapabileceği maksimum tur (araç çağrısı) sayısı.
# Maximum number of turns (tool calls) Claude Code can make in a single query.
CLAUDE_CODE_MAX_TURNS=1000

# Sorgu zaman aşımı milisaniye cinsinden; bu süre dolunca Bridge yanıtı keser.
# Query timeout in milliseconds; the Bridge aborts the response when this limit is reached.
CLAUDE_CODE_TIMEOUT_MS=1800000

# LLM çalışırken kullanıcıya gönderilecek "hâlâ çalışıyor" bildirimlerinin aralığı (ms).
# 0 = kapalı. Örnek: 120000 = 2 dk'da bir, 300000 = 5 dk'da bir.
# Interval in ms between "still working" progress notifications sent to the user while the LLM runs.
# 0 = disabled. Example: 120000 = every 2 min, 300000 = every 5 min.
CLAUDE_CODE_PROGRESS_INTERVAL_MS=120000

# Araç onayı için kullanıcıdan bekleme süresi (ms); bu süre dolunca onay zaman aşımına uğrar.
# How long (ms) to wait for the user to approve a tool call before timing out.
PERMISSION_APPROVAL_TIMEOUT_MS=300000

# FastAPI'nin Bridge'e yaptığı HTTP istekleri için bağlantı zaman aşımı (saniye).
# HTTP client timeout in seconds for FastAPI → Bridge requests.
BRIDGE_CLIENT_TIMEOUT=1800

# ── Yol Ayarları (isteğe bağlı) ──────────────────────────────────
# Varsayılan: repo kökünden otomatik hesaplanır. Değiştirmen gerekmez.
# Defaults are computed automatically from the repo root. No need to change.
# ROOT_DIR=/absolute/path/to/99-root
# PROJECTS_DIR=/absolute/path/to/99-root/data/projects
# SESSIONS_DIR=/absolute/path/to/99-root/data/claude_sessions
# CONV_HISTORY_DIR=/absolute/path/to/99-root/data/conv_history
# ACTIVE_CONTEXT_PATH=/absolute/path/to/99-root/data/active_context.json

# ── Webhook Proxy ────────────────────────────────────────────────
# Genel internet erişimi için kullanılacak tünel/proxy türü.
# Tunnel/proxy type used to expose the local server to the public internet.
WEBHOOK_PROXY=none

# WEBHOOK_PROXY=external seçildiğinde Meta'ya kaydedilecek genel URL.
# Public URL to register with Meta when WEBHOOK_PROXY=external.
# PUBLIC_URL=https://your-domain.com

# ngrok ücretsiz hesap authtoken'ı; WEBHOOK_PROXY=ngrok seçildiğinde opsiyonel.
# ngrok auth token for free-tier accounts; optional when WEBHOOK_PROXY=ngrok.
# NGROK_AUTHTOKEN=YOUR_NGROK_TOKEN
# Static domain from ngrok Dashboard → Domains (e.g. yourname.ngrok-free.app). Required for permanent URL.
# NGROK_DOMAIN=yourname.ngrok-free.app

# ── Messenger Adaptörü ───────────────────────────────────────────
# Aktif mesajlaşma platformu: whatsapp (varsayılan) | telegram | cli
# cli = terminale yazar, WhatsApp/Telegram hesabı olmadan yerel test için kullanılır.
# Active messaging platform: whatsapp (default) | telegram | cli
# cli = writes to stdout, useful for local testing without a WhatsApp/Telegram account.
MESSENGER_TYPE=whatsapp

# ── Telegram Bot API (MESSENGER_TYPE=telegram ise zorunlu) ───────
# BotFather'dan /newbot komutuyla alınan bot token'ı.
# Bot token obtained from BotFather via /newbot command.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Mesajların iletileceği owner'ın Telegram chat_id'si (tek kullanıcı sistemi).
# The owner's Telegram chat_id to which messages will be delivered (single-user system).
# TELEGRAM_CHAT_ID=987654321

# setWebhook çağrısında kullanılan gizli token; production'da zorunlu, geliştirmede opsiyonel.
# Secret token passed to setWebhook; mandatory in production, optional in development.
# TELEGRAM_WEBHOOK_SECRET=gizli_token

# ── Diğer ────────────────────────────────────────────────────────
# Bellek içi oturum (session) ne kadar süre aktif kalır (saat).
# How many hours an in-memory session stays alive before expiring.
SESSION_TTL_HOURS=24

# Uygulama ve Uvicorn log seviyesi.
# Application and Uvicorn log verbosity level.
LOG_LEVEL=INFO

# Kullanıcıya gönderilen mesajların varsayılan dili: tr (Türkçe) | en (İngilizce).
# Default language for messages sent to the user: tr (Turkish) | en (English).
DEFAULT_LANGUAGE=tr

# APScheduler ve tüm cron ifadeleri için kullanılacak saat dilimi (IANA adı).
# Timezone used by APScheduler and all cron expressions (IANA name).
TIMEZONE=Europe/Istanbul

# Uygulama ortamı; production'da hata ayrıntıları gizlenir.
# Application environment; in production mode, error details are hidden from responses.
ENVIRONMENT=development

# İzin verilen CORS origin'leri (virgülle ayrılmış); boş bırakılırsa CORS devre dışı.
# Comma-separated list of allowed CORS origins; leave empty to disable CORS.
# CORS_ORIGINS=http://localhost:5678

# ── Yetenek Kısıtlamaları (FEAT-3) ──────────────────────────────
# RESTRICT_* : false = aktif (varsayılan), true = kısıtlı
# *_ENABLED  : true = aktif (varsayılan), false = devre dışı  →  bkz. Desktop / Browser bölümleri
# install.sh --reconfigure-capabilities wizard'ı tüm bu flag'leri tek menüde sorar.
# RESTRICT_* : false = feature active (default), true = blocked
# *_ENABLED  : true = active (default), false = disabled  →  see Desktop / Browser sections

# Proje kök dizini dışındaki dosya sistemi yollarına erişimi kısıtlar.
# Restricts file system access to paths outside the project root directory.
RESTRICT_FS_OUTSIDE_ROOT=false

# Dış ağ isteklerini (HTTP/HTTPS çağrıları) kısıtlar.
# Restricts outbound network requests (HTTP/HTTPS calls).
RESTRICT_NETWORK=false

# Kabuk (bash/sh) komutu çalıştırmayı kısıtlar.
# Restricts shell (bash/sh) command execution.
RESTRICT_SHELL=false

# Systemd veya tmux gibi araçlarla servis yönetimini kısıtlar.
# Restricts service management via systemd, tmux, or similar tools.
RESTRICT_SERVICE_MGMT=false

# Gelen medya mesajlarını (görsel, video, belge, ses) kısıtlar.
# Restricts incoming media messages (image, video, document, audio).
# ⚠️  Değiştirdikten sonra `bash install.sh --reconfigure-capabilities` çalıştırın (Pillow paketi).
# ⚠️  After changing, run `bash install.sh --reconfigure-capabilities` (Pillow package).
RESTRICT_MEDIA=false

# Takvim ve zamanlanmış görev özelliklerini kısıtlar.
# Restricts calendar and scheduled task features.
# ⚠️  Değiştirdikten sonra `bash install.sh --reconfigure-capabilities` çalıştırın (dateparser paketi).
# ⚠️  After changing, run `bash install.sh --reconfigure-capabilities` (dateparser package).
RESTRICT_CALENDAR=false

# Proje oluşturma wizard'ını kısıtlar.
# Restricts the project creation wizard.
RESTRICT_PROJECT_WIZARD=false

# Headless tarayıcı ekran görüntüsü almayı kısıtlar.
# Restricts headless browser screenshot capture.
# ⚠️  Değiştirdikten sonra `bash install.sh --reconfigure-capabilities` çalıştırın (mss, Pillow paketleri).
# ⚠️  After changing, run `bash install.sh --reconfigure-capabilities` (mss, Pillow packages).
RESTRICT_SCREENSHOT=false

# APScheduler alt sistemini başlangıçta devre dışı bırakır; zamanlanmış görevler çalışmaz.
# Disables the APScheduler subsystem at startup; no scheduled tasks will run.
# ⚠️  Değiştirdikten sonra `bash install.sh --reconfigure-capabilities` çalıştırın (apscheduler, SQLAlchemy paketleri).
# ⚠️  After changing, run `bash install.sh --reconfigure-capabilities` (apscheduler, SQLAlchemy packages).
RESTRICT_SCHEDULER=false

# PDF içe aktarma hattını kısıtlar (RESTRICT_MEDIA=false olsa bile etkilidir).
# Restricts the PDF import pipeline (takes effect even if RESTRICT_MEDIA=false).
# ⚠️  Değiştirdikten sonra `bash install.sh --reconfigure-capabilities` çalıştırın (PyMuPDF paketi).
# ⚠️  After changing, run `bash install.sh --reconfigure-capabilities` (PyMuPDF package).
RESTRICT_PDF_IMPORT=false

# Konuşma geçmişinin SQLite'a kaydedilmesini kısıtlar (gizlilik için).
# Restricts saving conversation history to SQLite (for privacy).
RESTRICT_CONV_HISTORY=false

# İş planı oluşturma ve yönetimini kısıtlar (!plan komutları).
# Restricts work plan creation and management (!plan commands).
RESTRICT_PLANS=false

# LLM tabanlı niyet tespitini kısıtlar; her mesajda ek API çağrısı yapılmaz.
# Restricts LLM-based intent classification; no extra API call per message.
RESTRICT_INTENT_CLASSIFIER=false

# Wizard AI mimari önizlemesini kısıtlar (proje oluştururken LLM çağrısı yapar).
# Restricts wizard AI architecture preview (makes an LLM call during project creation).
RESTRICT_WIZARD_LLM_SCAFFOLD=false

# ── Desktop Otomasyon (FEAT-12) ──────────────────────────────────
# ⚠️  Bu değeri değiştirdikten sonra `bash install.sh --reconfigure-capabilities`
#    çalıştırılmalıdır; aksi hâlde gerekli Python paketleri kurulmaz/kaldırılmaz.
# ⚠️  After changing this value run `bash install.sh --reconfigure-capabilities`
#    so that required Python packages are installed/removed accordingly.
# false yapılırsa tüm /internal/desktop aksiyonları reddedilir.
# Set to false to disable all /internal/desktop actions.
DESKTOP_ENABLED=true

# sudo -S ve loginctl ile ekran kilidini açmak için sistem şifresi (loglara yazılmaz).
# System password used for sudo -S and loginctl screen unlock (never written to logs).
# SYSTEM_PSSWRD=your_system_password

# true yapılırsa record_screen aksiyonu etkinleşir.
# Set to true to enable the record_screen action.
DESKTOP_RECORDING=false

# Ekran kaydının maksimum dosya boyutu (MB); aşılırsa kayıt durdurulur.
# Maximum file size in MB for screen recordings; recording stops when exceeded.
DESKTOP_RECORDING_MAX_MB=128

# ── Tarayıcı Otomasyonu (FEAT-13/FEAT-15) ───────────────────────
# ⚠️  Bu değeri değiştirdikten sonra `bash install.sh --reconfigure-capabilities`
#    çalıştırılmalıdır; aksi hâlde gerekli Python paketleri kurulmaz/kaldırılmaz.
# ⚠️  After changing this value run `bash install.sh --reconfigure-capabilities`
#    so that required Python packages are installed/removed accordingly.
# false yapılırsa tüm /internal/browser aksiyonları reddedilir.
# Set to false to disable all /internal/browser actions.
BROWSER_ENABLED=true

# false yapılırsa Chromium görünür bir pencerede açılır (debug için kullanışlı).
# Set to false to run Chromium in a visible window (useful for debugging).
BROWSER_HEADLESS=true

# Disk kalıcı tarayıcı oturum dosyalarının (cookie vb.) saklanacağı dizin.
# Directory where persistent browser session files (cookies, etc.) are stored on disk.
BROWSER_SESSIONS_DIR=data/browser_sessions

# ── Site-özel credential store (FEAT-16) ─────────────────────────
# Format: CREDENTIAL_<SITE_SLUG>_USER ve CREDENTIAL_<SITE_SLUG>_PASS
# site_slug: site adındaki nokta/tire yerine alt çizgi kullan
# Claude bu değerleri okuyarak otomatik form doldurabilir (hardcode gerekmez)
# Format: CREDENTIAL_<SITE_SLUG>_USER and CREDENTIAL_<SITE_SLUG>_PASS
# site_slug: replace dots/dashes in the site name with underscores
# Claude reads these values to auto-fill login forms (no hardcoding needed)
# Usage: {"action": "get_credential", "site_slug": "github", "field": "user"}
#        {"action": "list_credentials"}
# Examples / Örnekler:
# CREDENTIAL_GITHUB_USER=emin
# CREDENTIAL_GITHUB_PASS=ghp_xxxxxxxxxx

# ── Docker Host Dosya Sistemi Erişimi ────────────────────────────
# Sadece Docker modunda etkilidir; install.sh --docker wizard'ı bu değeri yazar.
# none → host'a erişim yok (varsayılan)
# ro   → tüm host dizinleri /app/host_root altında salt-okunur
# rw   → tüm host dizinleri /app/host_root altında okuma+yazma+silme+düzenleme
# Only applies in Docker mode; the install.sh --docker wizard writes this value.
HOST_FS_ACCESS=none
